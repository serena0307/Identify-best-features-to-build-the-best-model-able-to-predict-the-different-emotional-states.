        "#############SCRIPT FOR FEATURE IMPORTANCES#####################\n",
        "\n",
        "# Feature importances from Random Forest\n",
        "feature_importances = rf_best_model.feature_importances_\n",
        "\n",
        "# Create a DataFrame to display feature importances\n",
        "feature_importance_df = pd.DataFrame({'Feature': X.columns, 'Importance': feature_importances})\n",
        "\n",
        "# Sort the DataFrame by importance in descending order\n",
        "feature_importance_df = feature_importance_df.sort_values(by='Importance', ascending=False)\n",
        "\n",
        "# Display the sorted feature importances\n",
        "print(\"Feature Importances:\")\n",
        "print(feature_importance_df)\n",
        "\n",
        "# Plot the feature importances\n",
        "#plt.figure(figsize=(10, 6))\n",
        "#sns.barplot(x='Importance', y='Feature', data=feature_importance_df, palette='viridis')\n",
        "#plt.title('Feature Importances - Random Forest')\n",
        "#plt.show()\n",
        "\n",
        "\n",
        "# Logistic Regression coefficients\n",
        "logreg_coefficients = lr_best_model.coef_[0]\n",
        "\n",
        "# Create a DataFrame to display feature importances\n",
        "feature_importance_df_logreg = pd.DataFrame({'Feature': X.columns, 'Coefficient': logreg_coefficients})\n",
        "\n",
        "# Sort the DataFrame by coefficient magnitude\n",
        "feature_importance_df_logreg['Coefficient_Magnitude'] = feature_importance_df_logreg['Coefficient'].abs()\n",
        "feature_importance_df_logreg = feature_importance_df_logreg.sort_values(by='Coefficient_Magnitude', ascending=False)\n",
        "\n",
        "# Display the sorted feature importances\n",
        "print(\"Feature Importances - Logistic Regression:\")\n",
        "print(feature_importance_df_logreg[['Feature', 'Coefficient']])\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "##SVM feature importance\n",
        "\n",
        "# Calculate permutation importances\n",
        "perm_importance = permutation_importance(svm_best_model, X_test_scaled, y_test, n_repeats=30, random_state=0)\n",
        "\n",
        "# Create a DataFrame to display feature importances\n",
        "feature_importance_df_permutation = pd.DataFrame({'Feature': X.columns, 'Importance': perm_importance.importances_mean})\n",
        "\n",
        "# Sort the DataFrame by importance\n",
        "feature_importance_df_permutation = feature_importance_df_permutation.sort_values(by='Importance', ascending=False)\n",
        "\n",
        "# Display the sorted feature importances\n",
        "print(\"Permutation Feature Importances - Support Vector Machine (Non-Linear):\")\n",
        "print(feature_importance_df_permutation[['Feature', 'Importance']])\n",
        "\n",
        "\n",
        "###KNN feature importance\n",
        "\n",
        "perm_importance = permutation_importance(knn_best_model, X_test_scaled, y_test, n_repeats=30, random_state=0)\n",
        "sorted_idx = perm_importance.importances_mean.argsort()\n",
        "\n",
        "# Display feature importances\n",
        "print(\"Permutation Importances - K-Nearest Neighbors:\")\n",
        "print(pd.DataFrame({'Feature': X.columns[sorted_idx], 'Importance': perm_importance.importances_mean[sorted_idx]}))\n",
        "\n",
        "\n",
        "\n",
        "# Feature importances from Decision Tree\n",
        "feature_importances_dt = dt_best_model.feature_importances_\n",
        "\n",
        "# Create a DataFrame to display feature importances\n",
        "feature_importance_df_dt = pd.DataFrame({'Feature': X.columns, 'Importance': feature_importances_dt})\n",
        "\n",
        "# Sort the DataFrame by importance in descending order\n",
        "feature_importance_df_dt = feature_importance_df_dt.sort_values(by='Importance', ascending=False)\n",
        "\n",
        "# Display the sorted feature importances\n",
        "print(\"Feature Importances - Decision Tree:\")\n",
        "print(feature_importance_df_dt)\n",
        "\n",
        "'''\n",
        "# Train  Bagging model with Random Forest as the base estimator\n",
        "best_bagging_rf_model.fit(X_train_scaled, y_train)\n",
        "\n",
        "# Extract the base RandomForestClassifier model\n",
        "base_rf_model = best_bagging_rf_model.base_estimator_\n",
        "\n",
        "# Get feature importances from the base RandomForestClassifier model\n",
        "feature_importances = base_rf_model.feature_importances_\n",
        "\n",
        "# Sort and display feature importances\n",
