        "\n",
        "# Train Gradient Boosting model with the best hyperparameters\n",
        "best_gradientboost_model.fit(X_train_scaled, y_train)\n",
        "\n",
        "# Get feature importances from the trained Gradient Boosting model\n",
        "feature_importances_gb = best_gradientboost_model.feature_importances_\n",
        "\n",
        "# Sort and display feature importances\n",
        "sorted_feature_importances_gb = sorted(zip(X_train.columns, feature_importances_gb), key=lambda x: x[1], reverse=True)\n",
        "for feature, importance in sorted_feature_importances_gb:\n",
        "    print(f\"{feature}: {importance}\")\n",
        "\n",
        "\n",
        "\n",
        "# Assuming you have a list of base models (rf_best_model, lr_best_model, knn_best_model, etc.)\n",
        "base_models = [rf_best_model, lr_best_model, knn_best_model, svm_best_model, dt_best_model]\n",
        "\n",
        "base_model_importances = pd.DataFrame()\n",
        "\n",
        "for i, base_model in enumerate(base_models):\n",
        "    if hasattr(base_model, 'feature_importances_'):\n",
        "        base_model_importances[f'Base_Model_{i+1}_Importance'] = base_model.feature_importances_\n",
        "    elif hasattr(base_model, 'coef_'):\n",
        "        # For models with coefficients (e.g., Logistic Regression)\n",
        "        if len(base_model.coef_.shape) == 1:\n",
        "            # If it's a binary classification problem, reshape the coefficients\n",
        "            base_model_importances[f'Base_Model_{i+1}_Importance'] = np.abs(base_model.coef_).reshape(1, -1)\n",
        "        else:\n",
        "            # For multi-class problems, take the mean across classes\n",
        "            base_model_importances[f'Base_Model_{i+1}_Importance'] = np.abs(base_model.coef_).mean(axis=0)\n",
        "    else:\n",
        "        # Handle other cases as needed\n",
        "        print(f\"Warning: Feature importances not available for Base_Model_{i+1}\")\n",
        "\n",
        "# Display feature importances from base models\n",
        "print(\"Feature Importances -stacking Base Models:\")\n",
        "print(base_model_importances)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Feature importances from XGBoost\n",
        "feature_importances_xgboost = best_xgboost_model.feature_importances_\n",
        "\n",
        "# Create a DataFrame to display feature importances\n",
        "feature_importance_df_xgboost = pd.DataFrame({'Feature': X.columns, 'Importance': feature_importances_xgboost})\n",
        "\n",
        "# Sort the DataFrame by importance in descending order\n",
        "feature_importance_df_xgboost = feature_importance_df_xgboost.sort_values(by='Importance', ascending=False)\n",
        "\n",
        "# Display the sorted feature importances\n",
        "print(\"Feature Importances - XGBoost:\")\n",
        "print(feature_importance_df_xgboost)"
      ],
