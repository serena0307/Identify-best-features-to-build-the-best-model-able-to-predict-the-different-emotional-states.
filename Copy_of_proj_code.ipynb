        "\n",
        "########SCRIPT#########\n",
        "\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.model_selection import train_test_split, GridSearchCV\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.neighbors import KNeighborsClassifier\n",
        "from sklearn.svm import SVC\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.tree import DecisionTreeClassifier\n",
        "from sklearn.naive_bayes import GaussianNB\n",
        "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, classification_report, confusion_matrix\n",
        "from sklearn.feature_selection import SelectFromModel\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from imblearn.over_sampling import SMOTE\n",
        "from imblearn.under_sampling import RandomUnderSampler\n",
        "from imblearn.over_sampling import RandomOverSampler\n",
        "from sklearn.ensemble import VotingClassifier\n",
        "from xgboost import XGBClassifier\n",
        "from sklearn.model_selection import GridSearchCV\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "from sklearn.inspection import permutation_importance\n",
        "\n",
        "def print_model_evaluation(model, X_train, y_train, X_test, y_test, model_name):\n",
        "    # Train and predict\n",
        "    model.fit(X_train, y_train)\n",
        "    y_pred = model.predict(X_test)\n",
        "\n",
        "    # Metrics\n",
        "    accuracy = accuracy_score(y_test, y_pred) * 100\n",
        "    precision = precision_score(y_test, y_pred, average='weighted') * 100\n",
        "    recall = recall_score(y_test, y_pred, average='weighted') * 100\n",
        "    f1 = f1_score(y_test, y_pred, average='weighted') * 100\n",
        "\n",
        "    # Classification report and confusion matrix\n",
        "    class_report = classification_report(y_test, y_pred)\n",
        "    conf_matrix = confusion_matrix(y_test, y_pred)\n",
        "\n",
        "    %matplotlib inline\n",
        "    # Print results\n",
        "    print(f\"Model: {model_name}\")\n",
        "    print(f\"Accuracy: {accuracy:.2f}%\")\n",
        "    print(f\"Precision: {precision:.2f}%\")\n",
        "    print(f\"Recall: {recall:.2f}%\")\n",
        "    print(f\"F1 Score: {f1:.2f}%\")\n",
        "    print(\"\\nClassification Report:\")\n",
        "    print(class_report)\n",
        "    plt.figure(figsize=(4, 2))\n",
        "    sns.heatmap(pd.DataFrame(conf_matrix), annot=True, cmap=\"YlGnBu\", fmt='g')\n",
        "    plt.tight_layout()\n",
        "    plt.title('Confusion matrix', y=1)\n",
        "    plt.ylabel('Actual label')\n",
        "    plt.xlabel('Predicted label')\n",
        "    plt.show()\n",
        "\n",
        "# Load the dataset\n",
        "df = pd.read_csv(\"/content/drive/MyDrive/Dataset_Study2.csv\")\n",
        "\n",
        "df.shape\n",
        "\n",
        "df.head()\n",
        "\n",
        "df.dtypes\n",
        "\n",
        "df.columns\n",
        "\n",
        "df.duplicated().sum()\n",
        "\n",
        "df.isnull().sum()\n",
        "\n",
        "# Remove duplicates\n",
        "df = df.drop_duplicates()\n",
        "\n",
        "#check shape\n",
        "df.shape\n",
        "\n",
        "#check label counts\n",
        "df['Label'].value_counts()\n",
        "\n",
        "#data visualisation\n",
        "df.hist(figsize=(12, 10), bins=30, edgecolor=\"black\")\n",
        "plt.subplots_adjust(hspace=0.7, wspace=0.4)\n",
        "\n",
        "#box plot\n",
        "plt.figure(figsize=(10, 8))\n",
        "df.boxplot()\n",
        "plt.title('Box Plots for Dataset_Study2 Features')\n",
        "plt.xticks(rotation=45)\n",
        "plt.grid(False)\n",
        "plt.show()\n",
        "\n",
        "\n",
        "#drop unnecessary column as they exist\n",
        "df_clean = df.copy()\n",
        "df_clean = df_clean.drop('HRV_LF', axis=1)\n",
        "df_clean = df_clean.drop('HRV_HF', axis=1)\n",
        "df_clean = df_clean.drop('HRV_SD1', axis=1)\n",
        "df_clean = df_clean.drop('HRV_SD2', axis=1)\n",
        "\n",
        "df_clean.shape\n",
        "\n",
        "#after cleaning data do corr matrix\n",
        "# Computing correlation matrix\n",
        "corr_matrix = df_clean.corr(numeric_only=True)\n",
        "\n",
        "# Plot heatmap\n",
        "plt.figure(figsize=(12, 10))\n",
        "sns.heatmap(corr_matrix, cmap='coolwarm', annot=True,vmin=-1, vmax=1, linewidths=0.5, square=True)\n",
        "plt.title('Correlation Plot (Corrplot) of mtcars variables')\n",
        "plt.show()\n",
        "\n",
        "\n",
        "# Class Imbalance Handling (Using SMOTE)\n",
        "#X = df_clean.drop('Label', axis=1)\n",
        "#y = df_clean['Label']\n",
        "#smote = SMOTE(random_state=0)\n",
        "#X_resampled, y_resampled = smote.fit_resample(X, y)\n",
        "\n",
        "# Class Imbalance Handling (Using Random Under-Sampling)\n",
        "X = df_clean.drop('Label', axis=1)\n",
        "y = df_clean['Label']\n",
        "#rus = RandomUnderSampler(random_state=0)\n",
        "#X_resampled, y_resampled = rus.fit_resample(X, y)\n",
        "\n",
        "# Random Over-Sampling\n",
        "ros = RandomOverSampler(random_state=0)\n",
        "X_resampled, y_resampled = ros.fit_resample(X, y)\n",
        "\n",
        "\n",
        "\n",
        "# Splitting the data into training and testing sets (80-20 split)\n",
        "X_train, X_test, y_train, y_test = train_test_split(X_resampled, y_resampled, test_size=0.2, random_state=0)\n",
        "\n",
        "\n",
        "\n",
        "# Standardize features\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "# Random Forest with hyperparameter tuning\n",
        "rf_param_grid = {'n_estimators': [50, 100, 200], 'max_depth': [None, 10, 20], 'min_samples_split': [2, 5, 10]}\n",
        "rf_grid_search = GridSearchCV(RandomForestClassifier(random_state=0), rf_param_grid, cv=5, scoring='accuracy')\n",
        "rf_grid_search.fit(X_train_scaled, y_train)\n",
        "rf_best_model = rf_grid_search.best_estimator_\n",
        "\n",
        "# Print results for Random Forest\n",
        "print(f\"Best Hyperparameters for Random Forest: {rf_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(rf_best_model, X_train_scaled, y_train, X_test_scaled, y_test, 'Random Forest')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Logistic Regression with hyperparameter tuning\n",
        "lr_param_grid = {'C': [0.001, 0.01, 0.1, 1, 10, 100], 'penalty': ['l2']}\n",
        "lr_grid_search = GridSearchCV(LogisticRegression(random_state=0, max_iter=1000), lr_param_grid, cv=5, scoring='accuracy')\n",
        "lr_grid_search.fit(X_train_scaled, y_train)\n",
        "lr_best_model = lr_grid_search.best_estimator_\n",
        "\n",
        "# Print results for Logistic Regression\n",
        "print(f\"Best Hyperparameters for Logistic Regression: {lr_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(lr_best_model, X_train_scaled, y_train, X_test_scaled, y_test, 'Logistic Regression')\n",
        "\n",
        "\n",
        "\n",
        "# K-Nearest Neighbors with hyperparameter tuning\n",
        "knn_param_grid = {'n_neighbors': [5, 10, 15], 'weights': ['uniform', 'distance']}\n",
        "knn_grid_search = GridSearchCV(KNeighborsClassifier(), knn_param_grid, cv=5, scoring='accuracy')\n",
        "knn_grid_search.fit(X_train_scaled, y_train)\n",
        "knn_best_model = knn_grid_search.best_estimator_\n",
        "\n",
        "# Print results for K-Nearest Neighbors\n",
        "print(f\"Best Hyperparameters for K-Nearest Neighbors: {knn_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(knn_best_model, X_train_scaled, y_train, X_test_scaled, y_test, 'K-Nearest Neighbors')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Support Vector Machine with hyperparameter tuning\n",
        "svm_param_grid = {'C': [0.1, 1, 10], 'kernel': ['linear', 'rbf'], 'gamma': ['scale', 'auto']}\n",
        "svm_grid_search = GridSearchCV(SVC(), svm_param_grid, cv=5, scoring='accuracy')\n",
        "svm_grid_search.fit(X_train_scaled, y_train)\n",
        "svm_best_model = svm_grid_search.best_estimator_\n",
        "\n",
        "# Print results for Support Vector Machine\n",
        "print(f\"Best Hyperparameters for Support Vector Machine: {svm_grid_search.best_params_}\")\n",
        "print_model_evaluation(svm_best_model, X_train_scaled, y_train, X_test_scaled, y_test, 'Support Vector Machine')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Decision Tree with hyperparameter tuning\n",
        "dt_param_grid = {'criterion': ['gini', 'entropy'], 'max_depth': [None, 10, 20, 30], 'min_samples_split': [2, 5, 10]}\n",
        "dt_grid_search = GridSearchCV(DecisionTreeClassifier(random_state=0), dt_param_grid, cv=5, scoring='accuracy')\n",
        "dt_grid_search.fit(X_train_scaled, y_train)\n",
        "dt_best_model = dt_grid_search.best_estimator_\n",
        "\n",
        "# Print results for Decision Tree\n",
        "print(f\"Best Hyperparameters for Decision Tree: {dt_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(dt_best_model, X_train_scaled, y_train, X_test_scaled, y_test, 'Decision Tree')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Naive Bayes (No hyperparameter tuning needed)\n",
        "nb_model = GaussianNB()\n",
        "print_model_evaluation(nb_model, X_train_scaled, y_train, X_test_scaled, y_test, 'Naive Bayes')\n",
        "\n",
        "from sklearn.ensemble import VotingClassifier\n",
        "from sklearn.ensemble import BaggingClassifier\n",
        "from sklearn.model_selection import GridSearchCV, StratifiedKFold\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "\n",
        "# Define the base model (Random Forest)\n",
        "base_model_rf = RandomForestClassifier(random_state=0)\n",
        "\n",
        "# Bagging with Random Forest\n",
        "bagging_rf_model = BaggingClassifier(base_estimator=base_model_rf, random_state=0)\n",
        "\n",
        "# Hyperparameter tuning using GridSearchCV\n",
        "param_grid_bagging_rf = {\n",
        "    'n_estimators': [50, 100, 200],\n",
        "    'max_samples': [0.5, 0.7, 1.0],\n",
        "    'max_features': [0.5, 0.7, 1.0]\n",
        "}\n",
        "\n",
        "grid_search_bagging_rf = GridSearchCV(estimator=bagging_rf_model, param_grid=param_grid_bagging_rf, cv=5, scoring='accuracy', n_jobs=1)\n",
        "\n",
        "grid_search_bagging_rf.fit(X_train_scaled, y_train)\n",
        "\n",
        "# Get the best model from hyperparameter tuning\n",
        "best_bagging_rf_model = grid_search_bagging_rf.best_estimator_\n",
        "\n",
        "# Print results for the best Bagging model with Random Forest\n",
        "print(f\"Best Hyperparameters for Bagging with Random Forest: {grid_search_bagging_rf.best_params_}\")\n",
        "\n",
        "print_model_evaluation(best_bagging_rf_model, X_train_scaled, y_train, X_test_scaled, y_test, ' Bagging (Random Forest)')\n",
        "\n",
        "###just for imbalaced dataset testng (because take time)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# Stacking with RandomForest as the final estimator\n",
        "stacking_model = StackingClassifier(\n",
        "    estimators=[\n",
        "        ('RandomForest', rf_best_model),\n",
        "        ('LogisticRegression', lr_best_model),\n",
        "        ('KNN', knn_best_model),\n",
        "        ('SVM', svm_best_model),\n",
        "        ('DecisionTree', dt_best_model)\n",
        "    ],\n",
        "    final_estimator=RandomForestClassifier(random_state=0),\n",
        "    stack_method='auto',  # 'auto' to automatically select stacking method\n",
        "    n_jobs=-1  # Use all processors\n",
        ")\n",
        "\n",
        "# Define hyperparameter grid for Stacking model\n",
        "stacking_param_grid = {\n",
        "    'final_estimator__n_estimators': [50, 100, 200],\n",
        "    'final_estimator__max_depth': [None, 10, 20],\n",
        "    'final_estimator__min_samples_split': [2, 5, 10]\n",
        "}\n",
        "\n",
        "# Create GridSearchCV for Stacking model\n",
        "stacking_grid_search = GridSearchCV(stacking_model, stacking_param_grid, cv=5, scoring='accuracy', n_jobs=-1)\n",
        "stacking_grid_search.fit(X_train_scaled, y_train)\n",
        "\n",
        "# Get the best Stacking model from hyperparameter tuning\n",
        "best_stacking_model = stacking_grid_search.best_estimator_\n",
        "\n",
        "# Print results for the best Stacking model\n",
        "print(f\"Best Hyperparameters for Stacking: {stacking_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(best_stacking_model, X_train_scaled, y_train, X_test_scaled, y_test, ' Stacking')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "from sklearn.ensemble import GradientBoostingClassifier\n",
        "\n",
        "# Gradient Boosting as the base model for Boosting\n",
        "base_model_gb = GradientBoostingClassifier(n_estimators=100, learning_rate=0.1, max_depth=3, random_state=0)\n",
        "\n",
        "# Hyperparameter tuning using GridSearchCV\n",
        "param_grid_gb = {\n",
        "    'n_estimators': [50, 100, 200],\n",
        "    'learning_rate': [0.01, 0.1, 0.2],\n",
        "    'max_depth': [3, 5, 7]\n",
        "}\n",
        "\n",
        "grid_search_gb = GridSearchCV(base_model_gb, param_grid_gb, cv=5, scoring='accuracy', n_jobs=1)\n",
        "grid_search_gb.fit(X_train_scaled, y_train)\n",
        "\n",
        "# Get the best model from hyperparameter tuning\n",
        "best_gradientboost_model = grid_search_gb.best_estimator_\n",
        "\n",
        "# Print results for the best Gradient Boosting model\n",
        "print(f\"Best Hyperparameters for Gradient Boosting: {grid_search_gb.best_params_}\")\n",
        "\n",
        "print_model_evaluation(best_gradientboost_model, X_train_scaled, y_train, X_test_scaled, y_test, ' Boosting (Gradient Boosting)')\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "##xgboost(ensemble)\n",
        "# Encode the target variable\n",
        "label_encoder = LabelEncoder()\n",
        "y_train_encoded = label_encoder.fit_transform(y_train)\n",
        "y_test_encoded = label_encoder.transform(y_test)\n",
        "\n",
        "# XGBoost model\n",
        "xgboost_model = XGBClassifier(random_state=0)\n",
        "\n",
        "# Define hyperparameter grid for XGBoost model\n",
        "xgboost_param_grid = {\n",
        "    'n_estimators': [50, 100, 200],\n",
        "    'learning_rate': [0.01, 0.1, 0.2],\n",
        "    'max_depth': [3, 5, 7],\n",
        "    'min_child_weight': [1, 3, 5]\n",
        "}\n",
        "\n",
        "# Create GridSearchCV for XGBoost model\n",
        "xgboost_grid_search = GridSearchCV(xgboost_model, xgboost_param_grid, cv=5, scoring='accuracy', n_jobs=-1)\n",
        "xgboost_grid_search.fit(X_train_scaled, y_train_encoded)\n",
        "\n",
        "# Get the best XGBoost model from hyperparameter tuning\n",
        "best_xgboost_model = xgboost_grid_search.best_estimator_\n",
        "\n",
        "# Print results for the best XGBoost model\n",
        "print(f\"Best Hyperparameters for XGBoost: {xgboost_grid_search.best_params_}\")\n",
        "\n",
        "print_model_evaluation(best_xgboost_model, X_train_scaled, y_train_encoded, X_test_scaled, y_test_encoded, ' XGBoost')"
